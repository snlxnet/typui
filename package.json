{
  "name": "typui",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev-server\" \"npm run dev-client\"",
    "dev-server": "TYPUI_DIR=./src concurrently \"npm run build-server -- --watch\" \"node --watch server.js\"",
    "dev-client": "vite build --watch",
    "build-server": "rolldown -c",
    "build-client": "vite build",
    "build": "npm run build-client && npm run build-server",
    "start": "node server.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "rolldown": "^1.1.5",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vite": "^8.1.4",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
